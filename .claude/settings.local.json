{
  "permissions": {
    "allow": [
      "mcp__Context7__resolve-library-id",
      "mcp__Context7__get-library-docs",
      "Bash(npm run build:*)",
      "Bash(npm install)",
      "Bash(npx ray:*)",
      "Bash(rm:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run lint)",
      "Bash(npm run fix-lint)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["Context7"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "git add . && oco --yes"
          }
        ]
      }
    ]
  }
}
